# --- Core app runtime ---
NODE_ENV=development
CRON_SECRET=change-me-to-a-long-random-secret

# --- Database ---
# Local defaults:
DB_PROVIDER=sqlite
SQLITE_DB_PATH=./newsletter.db

# Production (Railway Postgres):
# DB_PROVIDER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Newsletter ingestion ---
# Optional comma-separated fallback feed URLs. User settings can override per user.
RSS_FEEDS=https://example.com/feed.xml,https://another.com/rss

# --- Summarization model endpoint (required for summarize routes) ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=your-ollama-model-name
OLLAMA_CONCURRENCY=2

# --- Optional semantic search embeddings ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
